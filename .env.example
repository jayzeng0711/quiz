APP_NAME="職場溝通風格測驗"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# ⚠️ 上線前務必改為真實網域，否則 email 中的連結會指向 localhost
APP_URL=http://localhost

APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_TW

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------
# Database
# ---------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quiz
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# ⚠️ 上線後改為 redis 或 sqs，避免 queue 佔用 DB 連線
QUEUE_CONNECTION=database

CACHE_STORE=database

# ---------------------------------------------------------
# Email
# ---------------------------------------------------------
# 開發環境：log（寫入 storage/logs/laravel.log）
# 正式環境推薦：resend | mailgun | ses
#
# Resend 設定（免費方案每月 3000 封）：
#   MAIL_MAILER=resend
#   RESEND_KEY=re_xxxxxxxxxxxx
#
# Mailgun 設定：
#   MAIL_MAILER=mailgun
#   MAILGUN_DOMAIN=mg.yourdomain.com
#   MAILGUN_SECRET=key-xxxxxxxxxxxxx
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# ⚠️ 改為你的真實寄件地址
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------
# Payment Gateway
# ---------------------------------------------------------
# 開發環境：mock（使用內建模擬付款頁）
# 正式環境：ecpay（綠界金流）
#
# ECPay 沙箱測試帳號（可直接用於 sandbox 測試）：
#   ECPAY_MERCHANT_ID=2000132
#   ECPAY_HASH_KEY=5294y06JbISpM5x9
#   ECPAY_HASH_IV=v77hoKGq4kWxNNIS
#
# 正式帳號請至 https://www.ecpay.com.tw/ 申請
PAYMENT_PROVIDER=mock

# Stripe（本地測試：填入 test key 後改 PAYMENT_PROVIDER=stripe）
# 測試卡號：4242 4242 4242 4242，任何未來日期，任何 CVC
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_ENV=sandbox

# ---------------------------------------------------------
# OpenAI（Phase 3 AI 個人化報告）
# ---------------------------------------------------------
# 申請：https://platform.openai.com/api-keys
# 費用：gpt-4o-mini 約 NT$0.006/次，幾乎可忽略
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
# 推薦模型：gpt-4o-mini（便宜+快速） 或 gpt-4o（品質更高）
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------
# AWS（PDF 儲存用，可選）
# ---------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
